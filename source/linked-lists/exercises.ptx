  <exercise label="linked-list_exercise_linkedlist-insertEnd" xml:id="linked-list_exercise_linkedlist-insertEnd">
    <statement>
      <p>
        Finish the <pf>insertEnd</pf> function for the <xref ref="LinkedList-cxx-listing" text="custom">Linked List</xref> (with size and tail).
      </p>
    </statement>
    <program interactive="activecode"
           compile-also="LinkedList-cxx">
        <preamble visible="no"><![CDATA[
#define DOCTEST_CONFIG_IMPLEMENT_WITH_MAIN
#include "doctest.h"

import LinkedList;

#include <iostream>
using namespace std;]]>
        </preamble>
        <code>
          <![CDATA[
template<typename T>
void LinkedList<T>::insertEnd(const T& value) {
    ListNode<T>* newNode = new ListNode<T>(value);
    if (size == 0) {
      // node is both head and tail
    } else {
      // attach to end of list and update tail
    }
    size++;
}
]]>
</code>
    <tests visible="yes"><![CDATA[
template<typename T>
void LinkedList<T>::clear() {
  // placeholder implementation
}

void buildTestIntList(LinkedList<int>& list) {
  list.insertStart(3);
  list.insertStart(2);
  list.insertStart(1);
}

TEST_CASE("LL/InsertEnd") {
  LinkedList<int> test_list;
  buildTestIntList(test_list); // 1, 2, 3

  test_list.insertEnd(10);
  REQUIRE(test_list.size == 4);
  REQUIRE(test_list.retrieveAt(3) == 10);
  REQUIRE(test_list.tail->data == 10);      // check tail pointer
  REQUIRE(test_list.tail->next == nullptr); // check after tail

  test_list.insertEnd(20);
  REQUIRE(test_list.size == 5);
  REQUIRE(test_list.retrieveAt(4) == 20);
  REQUIRE(test_list.tail->data == 20);      // check tail pointer
  REQUIRE(test_list.tail->next == nullptr); // check after tail
}

TEST_CASE("LL/InsertEndEmptyList") {
  LinkedList<int> test_list;

  test_list.insertEnd(10);
  REQUIRE(test_list.head != nullptr); // check head pointer
  REQUIRE(test_list.size == 1);
  REQUIRE(test_list.retrieveAt(0) == 10);
  REQUIRE(test_list.head->data == 10);      // check head pointer
  REQUIRE(test_list.tail->data == 10);      // check tail pointer
  REQUIRE(test_list.tail->next == nullptr); // check after tail
}
]]>
    </tests>
    </program>
  </exercise>

  <exercise label="linked-list_exercise_linkedlist-clear">
    <statement>
      <p>
        Write the <pf>clear</pf> function for the <xref ref="LinkedList-cxx-listing" text="custom">Linked List</xref> (with size and tail).
      </p>
      <p>
        You can copy/paste in your <pf>removeStart</pf> from <xref ref="linked-list_exercise_linkedlist-removefirst"/> to help with this implementation.
      </p>
    </statement>
    <program interactive="activecode"
           compile-also="LinkedList-cxx">
        <preamble visible="no"><![CDATA[
#define DOCTEST_CONFIG_IMPLEMENT_WITH_MAIN
#include "doctest.h"

import LinkedList;

#include <iostream>
using namespace std;]]>
        </preamble>
        <code>
          <![CDATA[
template<typename T>
void LinkedList<T>::clear() {
  // Your code here
}

]]>
</code>
    <tests visible="yes"><![CDATA[
void buildTestIntList(LinkedList<int>& list) {
  list.insertStart(3);
  list.insertStart(2);
  list.insertStart(1);
}

TEST_CASE("LL/Clear") {
  LinkedList<int> test_list;
  buildTestIntList(test_list); // 1, 2, 3

  int startNodeCount = ListNode<int>::nodeCount;

  test_list.clear();

  REQUIRE(test_list.head == nullptr);
  REQUIRE(test_list.tail == nullptr);
  REQUIRE(test_list.size == 0);
  // Were they actually deleted???
  REQUIRE(startNodeCount - ListNode<int>::nodeCount == 3);
}
]]>
    </tests>
    </program>
  </exercise>

  
  <exercise label="linked-list_exercise_linkedlist-copy">
    <statement>
      <p>
        Write the <pf>copyFrom</pf> function for the <xref ref="LinkedList-cxx-listing" text="custom">Linked List</xref> (with size and tail).
      </p>
      <p>
        You should use your <pf>insertEnd</pf> from <xref ref="linked-list_exercise_linkedlist-insertEnd"/> to simplify your implementation. You may assume the list starts out as a valid empty list.
      </p>
    </statement>
    <program interactive="activecode"
           compile-also="LinkedList-cxx">
        <preamble visible="no"><![CDATA[
#define DOCTEST_CONFIG_IMPLEMENT_WITH_MAIN
#include "doctest.h"

import LinkedList;

#include <iostream>
using namespace std;]]>
        </preamble>
        <code>
          <![CDATA[
template<typename T>
void LinkedList<T>::copyFrom(const LinkedList<T>& other) {
  // Your code here
}

]]>
</code>
    <tests visible="yes"><![CDATA[
template<typename T>
void LinkedList<T>::clear() {
  // placeholder implementation
}

template<typename T>
LinkedList<T>::LinkedList(const LinkedList<T>& other) {
  //copy constructor that uses your copyFrom
  head = nullptr;
  tail = nullptr;
  size = 0;
  copyFrom(other);
}


void buildTestIntList(LinkedList<int>& list) {
  list.insertStart(3);
  list.insertStart(2);
  list.insertStart(1);
}

TEST_CASE("LL/CopyConstructor") {
  LinkedList<int> test_list;
  buildTestIntList(test_list); // 1, 2, 3

  int startNodeCount = ListNode<int>::nodeCount;

  LinkedList<int> copy(test_list);

  REQUIRE(copy.retrieveAt(0) == 1);
  REQUIRE(copy.retrieveAt(1) == 2);
  REQUIRE(copy.retrieveAt(2) == 3);
  REQUIRE(copy.size == 3);
  REQUIRE(ListNode<int>::nodeCount - startNodeCount == 3);

  // Make sure changing one does not change the other
  test_list.insertStart(0);
  REQUIRE(copy.retrieveAt(0) == 1);
  REQUIRE(copy.retrieveAt(1) == 2);
  REQUIRE(copy.retrieveAt(2) == 3);
  REQUIRE(copy.size == 3);
}
]]>
    </tests>
    </program>
  </exercise>

  <exercise label="linked-list_exercise_dll-construct" xml:id="linked-list_exercise_dll-construct">
    <statement>
      <p>
        Write the <pf>constructor</pf> for the <xref ref="DoublyLinkedList-cxx-listing" text="custom">Doubly Linked List</xref>. You need to create an empty list with dummy nodes for head and tail that are connected together.
      </p>
      <p>
        To make a new node with a dummy (default) value, you can use <pf>ListNode&lt;T>(T{})</pf>
      </p>
    </statement>
    <program interactive="activecode"
           compile-also="DoublyLinkedList-cxx">
        <preamble visible="no"><![CDATA[
#define DOCTEST_CONFIG_IMPLEMENT_WITH_MAIN
#include "doctest.h"

import DoublyLinkedList;

#include <iostream>
using namespace std;]]>
        </preamble>
        <code>
          <![CDATA[
template<typename T>
DoublyLinkedList<T>::DoublyLinkedList() {
  // Your code here
}

]]>
</code>
    <tests visible="yes"><![CDATA[
TEST_CASE("DLL/Constructor") {
  int startNodeCount = ListNode<int>::nodeCount;

  DoublyLinkedList<int> test_list;

  REQUIRE(test_list.size == 0);
  REQUIRE(test_list.tail != nullptr);
  REQUIRE(test_list.head != nullptr);
  REQUIRE(test_list.tail->prev == test_list.head);
  REQUIRE(test_list.head->next == test_list.tail);
  REQUIRE(ListNode<int>::nodeCount - startNodeCount == 2); // dummies
}
]]>
    </tests>
    </program>
  </exercise>



  <exercise label="linked-list_exercise_dll-remove-end">
    <statement>
      <p>
        Write the <pf>removeEnd</pf> function for the <xref ref="DoublyLinkedList-cxx-listing" text="custom">Doubly Linked List</xref>. It should remove the node before the dummy tail node. You will have to add your constructor from <xref ref="linked-list_exercise_dll-construct"/>.
      </p>
    </statement>
    <program interactive="activecode"
           compile-also="DoublyLinkedList-cxx">
        <preamble visible="no"><![CDATA[
#define DOCTEST_CONFIG_IMPLEMENT_WITH_MAIN
#include "doctest.h"

import DoublyLinkedList;

#include <iostream>
using namespace std;]]>
        </preamble>
        <code>
          <![CDATA[

// Your constructor here

template<typename T>
void DoublyLinkedList<T>::removeEnd() {
  if (size == 0)
    throw out_of_range("Can't remove from empty list");

  // Your code here
}

]]>
</code>
    <tests visible="yes"><![CDATA[
TEST_CASE("DLL/removeEnd") {
  DoublyLinkedList<int> test_list;
  test_list.insertStart(40);
  test_list.insertStart(30);
  test_list.insertStart(20);
  test_list.insertStart(10);

  int startNodeCount = ListNode<int>::nodeCount;

  test_list.removeEnd();

  REQUIRE(test_list.size == 3);
  REQUIRE(test_list.retrieveAt(0) == 10);
  REQUIRE(test_list.retrieveAt(2) == 30);
  REQUIRE(startNodeCount - ListNode<int>::nodeCount == 1);

  test_list.removeEnd();
  test_list.removeEnd();

  REQUIRE(test_list.size == 1);
  REQUIRE(test_list.retrieveAt(0) == 10);
  REQUIRE(startNodeCount - ListNode<int>::nodeCount == 3);

  test_list.removeEnd();

  REQUIRE(test_list.size == 0);
  REQUIRE(startNodeCount - ListNode<int>::nodeCount == 4);
}
]]>
    </tests>
    </program>
  </exercise>

</exercises>
