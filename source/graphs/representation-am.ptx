        title: "Graph Representation",
        startingGraphRepresentation: "adjacency matrix",
        zoom: "1x"
      });
      anim.shift(300, -20);
    </script>
      <xi:include href="../../fragments/ds-graph-instructions.xml"/>
    </interactive>

  <activity>
