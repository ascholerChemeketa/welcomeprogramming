<section xml:id="trees_vocabulary"
         xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Vocabulary</title>
  <p>
    <dl>
      <li>
        <title>binary search tree</title>
        <p>
          <idx>
            <h>binary search tree</h>
          </idx> A binary tree where values in the left subtree
          are less than the node and values in the right subtree are greater than the node.</p>
      </li>
      <li>
        <title>binary tree</title>
        <p>
          <idx>
            <h>binary tree</h>
          </idx> A tree in which each node has at most two children.</p>
      </li>
      <li>
        <title>children</title>
        <p>
          <idx>
            <h>children</h>
          </idx> The nodes directly below a given node in a tree.</p>
      </li>
      <li>
        <title>depth</title>
        <p>
          <idx>
            <h>depth</h>
          </idx> The number of edges from the root to a given node.</p>
      </li>
      <li>
        <title>height</title>
        <p>
          <idx>
            <h>height</h>
          </idx> The number of edges on the longest path from a node to a
          leaf.</p>
      </li>
      <li>
        <title>in-order traversal</title>
        <p>
          <idx>
            <h>in-order traversal</h>
          </idx> A traversal that visits the left subtree, then
          the node, then the right subtree.</p>
      </li>
      <li>
        <title>internal nodes</title>
        <p>
          <idx>
            <h>internal nodes</h>
          </idx> Nodes that have at least one child.</p>
      </li>
      <li>
        <title>leaves</title>
        <p>
          <idx>
            <h>leaves</h>
          </idx> Nodes with no children.</p>
      </li>
      <li>
        <title>Node (Tree)</title>
        <p>
          <idx>
            <h>Node</h>
            <h>Tree</h>
          </idx> A tree element that stores a value and references to child
          nodes.</p>
      </li>
      <li>
        <title>parent node</title>
        <p>
          <idx>
            <h>parent node</h>
          </idx> The node directly above a given node in a tree.</p>
      </li>
      <li>
        <title>post-order traversal</title>
        <p>
          <idx>
            <h>post-order traversal</h>
          </idx> A traversal that visits the left subtree,
          then the right subtree, then the node.</p>
      </li>
      <li>
        <title>pre-order traversal</title>
        <p>
          <idx>
            <h>pre-order traversal</h>
          </idx> A traversal that visits the node, then the
          left subtree, then the right subtree.</p>
      </li>
      <li>
        <title>root</title>
        <p>
          <idx>
            <h>root</h>
          </idx> The top node of a tree, which has no parent.</p>
      </li>
      <li>
        <title>search tree</title>
        <p>
          <idx>
            <h>search tree</h>
          </idx> A tree organized so that comparisons can efficiently
          guide search.</p>
      </li>
      <li>
        <title>siblings</title>
        <p>
          <idx>
            <h>siblings</h>
          </idx> Nodes that share the same parent.</p>
      </li>
      <li>
        <title>size</title>
        <p>
          <idx>
            <h>size</h>
          </idx> The number of nodes in a tree or subtree.</p>
      </li>
      <li>
        <title>tree</title>
        <p>
          <idx>
            <h>tree</h>
          </idx> A data structure made of nodes connected by parent-child
          relationships. Every node in a tree has exactly one parent, except for the root node,
          which has no parent.</p>
      </li>
    </dl>
  </p>
</section>